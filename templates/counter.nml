doctype.html
html.lang("en")
    head
        title("Counter")
        script.src("/static/nml_runtime.js")
    body
        h1("Counter")
        button.on:click("nml('inc counter.count 1')")
            | +
        button.on:click("nml('inc counter.count -1')")
            | -
        span.data-nml-bind("text:counter.count")
