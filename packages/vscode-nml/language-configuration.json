{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["(", ")"],
    ["{", "}"],
    ["[", "]"],
    ["{{", "}}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "{{", "close": "}}" }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "{{", "close": "}}" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^(\\s*)([a-z][a-zA-Z0-9-]*|@define\\.[A-Z][a-zA-Z0-9]*|@if\\(.*\\)|@each\\(.*\\)|@else|@slot)([.\\s|].*)?$",
    "decreaseIndentPattern": "^(\\s*)(@endif|@endeach|@else)\\b"
  },
  "folding": {
    "offSide": true
  },
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_.-]*"
}
