{
  "name": "@nml-lang/bun-server",
  "version": "1.0.0",
  "description": "Minimal Bun HTTP server for NML applications using the universal fetch handler",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "bun run build:ts",
    "build:ts": "bun x tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@nml-lang/compiler-ts": "workspace:*",
    "@nml-lang/router": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
