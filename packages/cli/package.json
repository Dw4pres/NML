{
  "name": "@nml-lang/cli",
  "version": "2.2.1",
  "description": "NML command-line interface — init, dev, build, test, deploy",
  "type": "module",
  "bin": {
    "nml": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "nml": "bun run src/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Dw4pres/NML.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "@nml-lang/compiler-ts": "workspace:*",
    "@nml-lang/router": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  }
}
